@article{vega2023methionine,
  % Thesis: the authors posit that lung adenocarcinoma cells tend to select for methionine producing bacteria in the tumor microenvironment
  % Pre reading:
  %   Before I even read this paper, I decided to check out the elevated microbes in the Yan 2015 paper to see if they can synthesize methionine. 
  %   After way too much work, I decided to tentatively conclude that Capnocytophaga can probably synthesize methiothine. 
  %   I could not find direct evidence for or against this in the literature. Instead, I looked on OrthoDB for "metC", which led to me to group "9805807at2"
  %   When I looked in this group, I found evidence for metC orthologs not in genus Capnocytophaga, but instead in the genuses Aquimarina (Aquimarina atlantica) 
  %   and Tenacibaculum (Tenacibaculum sp. Bg11-29). I picked species on the simple basis of "what has a uniprot entry in this genus" (sidenote:
  %   the uniprot entries are NOT great). When I BLASTed the protein sequences in uniprot against each other, I got 78% sequence identity and 91% positives. 
  %   Given that these are both about as related to each other as they are to Capnocytophaga, I decided to conclude that it was likely that Capnocytophaga could 
  %   synthesize methionine, because the orthologs probably come from a common ancestor up the family tree, and it would be a funny coincidence if only Capnocytophaga
  %   lost the ability to synthesize methionine. 
  %   However, Veillonella does not have a metC ortholog. This doesn't mean anything decisive: it could have some other methiothine synthesis gene, and I'm too lazy to 
  %   check further. 
  %   Now, the Yan paper looked in oral microbiota, which is not the same as lung microbiota, but it's not nothing. 
  % My opinion:
  %   
  title={Methionine-producing tumor micro (be) environment fuels growth of solid tumors},
  author={Vega, Alexis A and Marshall, Erin A and Noonan, Avery JC and Filho, Fernando Sergio Leitao and Yang, Julia and Stewart, Greg L and Johnson, Fraser D and Vucic, Emily A and Pewarchuk, Michelle E and Shah, Parag P and others},
  journal={Cellular Oncology},
  volume={46},
  number={6},
  pages={1659--1673},
  year={2023},
  publisher={Springer}
}

