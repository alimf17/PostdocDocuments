@article{jin2019commensal,
  % Thesis: The authors claim that the lung microbiome can drive the development of lung cancer by activated gamma delta T cells, promoting neutrophil infiltration, inflammation, and tumor cell proliferation. 
  % My opinions: Before I even read the article, I was immediately sus. I don't think the authors are fundamentally _wrong_, but I definitely think the story has to be more complicated than "microbiome in lung bad"
  % These are my opinions as I read the article:
  %  The antibiotic nuke the researchers used is insane. Combining how much mouse drink in a day and comparing with high dose oral vancomycin in human adults indicated that the vancomycin in their antibiotic cocktail alone was about double the human staph infection amount relative to body weight. And they had three other drugs in there
  %  I can buy that they showed the microbiome mattering. I'm very annoyed that they made the thesis "lung microbiome bad" despite their own data showing that it was at least partially reduced diversity of the microbiome that matter. They barely showed that there was a correlation with the LUNG microbiome mattering more than the microbiome of other parts of the body. And that was just a correlation. Have they considered an aerosol of some kind to actually microbiome the lung?
  %  This is enough evidence to buy the possibility of lung microbiome being important, but the researchers were too reductive. And again, I can't get over the antibiotic nuke. 
  title={{Commensal microbiota promote lung cancer development via $\gamma$$\delta$ T cells}},
  author={Jin, Chengcheng and Lagoudas, Georgia K and Zhao, Chen and Bullman, Susan and Bhutkar, Arjun and Hu, Bo and Ameh, Samuel and Sandel, Demi and Liang, Xu Sue and Mazzilli, Sarah and others},
  journal={{Cell}},
  volume={176},
  number={5},
  pages={998--1013},
  year={2019},
  publisher={Elsevier}
  url={doi.org/10.1016/j.cell.2018.12.040}
}

@article{yan2015discovery,
  % Thesis: The authors claim to have found a decent classifier of lung cancer vs not based on oral microbiota, in particular by looking for elevated levels of Capnocytophaga and Veillonella in saliva. 
  % My opinions: Delicious. Finally, some good fucking food. 
  % Now, this might be of only so much help to me personally. This is a study that was specifically done on humans with a >10+ year history of smoking, and I'm specifically trying to do things on non smokers. 
  % But this study was done in China, and their rationale was the fairly simple, "[s]ince smoking may affect the growth of bacteria in the oral cavity, only subjects with a smoking history of over 10 years were selected"
  % I suspect strongly this was done out of availability: my understanding is that smoking rates in China are pretty high, and obviously P(smoking|Chinese lung cancer) > P(smoking|Chinese)
  % They also explicitly checked, "None of the subjects, including the patients and the controls, manifested other diseases related to salivary bacteria, such as diabetes, immune dysfunction, herpes viral infections, or oral mucosal ulcers"
  % The researchers looked for bacterial populations with elevated or reduced levels in saliva by comparing results in 30 people: 10 with squamous cell carcinoma, 10 with adenocarcinoma, and 10 patients without lung cancer. 
  % They found in their discovery group, "Capnocytophaga,  Selenomonas, and Veillonella were found to be more abundant in both SCC and AC patients, whereas Neisseria was less abundant in both SCC and AC patients than the controls"
  % When they validated, they did it on a new cohort of 56 people, (13 LUSC, 28 LUAD, 15 without cancer). Now, the main criticisms I have are all their samples are male biased and have a clear age difference between the groups (SCC older than AC older than control). Also, their cancer patients skewed heavily late stage
  % This is a minor criticism though: they noted it explicitly and I would put money on the table again that they were working with what they had. 
  % When they tried to validate, they found that the best classifier was looking for elevated  and Veillonella, without looking for reduced Neisseria (which seemed to spoil their classifer)
  % They also found that Veillonella tended to be better at discriminating LUSC than LUAD, while the inverse was marginally true for Capnocytophaga. 
  % They did note that while Nesseria wasn't particularly good at _discriminating_ cancer from not, the reduced levels are supported by other cancers showing similar things. 
  title={{Discovery and validation of potential bacterial biomarkers for lung cancer}},
  author={Yan, Xinmin and Yang, Mingxia and Liu, Juan and Gao, Ruichen and Hu, Jihong and Li, Jiong and Zhang, Lijun and Shi, Yujia and Guo, Hongrong and Cheng, Jinluo and others},
  journal={{American Journal of Cancer Research}},
  volume={5},
  number={10},
  pages={3111},
  year={2015}
  url={https://pmc.ncbi.nlm.nih.gov/articles/PMC4656734/}
}

@article{tsay2018airway,
  % Thesis: The authors claim to have evidence that the upregulation the PI3K pathway (the thing that EGFR enhances) in lung cancer is associated with (some?) microbiota in the airway
  % My opinions: 
  % Right off the bat, I'm slightly annoyed: Unlike the Yan paper, they did not distinguish between the non smokers and smokers other than to make a note of the existence of smokers and nonsmokers, despite the fact that smoking can alter the lung microbiome
  % They didn't even seem to do analyses with smokers and nonsmokers separately. 
  % Ok, this assessment turned out to be wrong: they at least made noises about adjusting for smoking status and finding nothing of note. 
  % Long story short: The authors found that Veillonella, Strep, and Prevotella seemed to be associated with cancer, and that they seem to be helping to upregulate the 
  % PI3K pathway, the ERK 1/2 pathway, and the VEGF pathway
  % Their statistics looked decent, but I probably want to read this again later, because I found it hard to follow their paper. 
  title={Airway microbiota is associated with upregulation of the PI3K pathway in lung cancer},
  author={Tsay, Jun-Chieh J and Wu, Benjamin G and Badri, Michelle H and Clemente, Jose C and Shen, Nan and Meyn, Peter and Li, Yonghua and Yie, Ting-An and Lhakhang, Tenzin and Olsen, Evan and others},
  journal={American Journal of Respiratory and Critical Care Medicine},
  volume={198},
  number={9},
  pages={1188--1198},
  year={2018},
  publisher={American Thoracic Society}
}

@article{Liu2018-ix,
  %I didn't read this in thorough detail, but I note it here because they reach the opposite conclusion about Neisseria than the Yan 2015 paper: Yan found Neisseria is associated with healthy lungs, while Liu found it's associate with canc. Though looking at some of their results, they admit it's not significant by their own statistical tests. 
  title    = "Lung tissue microbial profile in lung cancer is distinct from
              emphysema",
  author   = "Liu, Yanhong and O'Brien, Jacqueline L and Ajami, Nadim J and
              Scheurer, Michael E and Amirian, E Susan and Armstrong, Georgina
              and Tsavachidis, Spiridon and Thrift, Aaron P and Jiao, Li and
              Wong, Matthew C and Smith, Daniel P and Spitz, Margaret R and
              Bondy, Melissa L and Petrosino, Joseph F and Kheradmand, Farrah",
  abstract = "OBJECTIVES: The composition and structure of site-specific
              microbiota have been investigated as potential biomarkers for a
              variety of chronic inflammatory diseases and cancers. While many
              studies have focused on the changes in the airway microbiota
              using respiratory specimens from patients with various
              respiratory diseases, more research is needed to explore the
              microbial profiles within the distal lung parenchyma in smokers
              with lung cancer and/or emphysema. MATERIALS AND METHODS: To
              describe and contrast lung tissue-associated microbial signatures
              in smokers with lung cancer and/or emphysema, we employed
              culture-independent pyrosequencing of 16S rRNA gene hypervariable
              V4 region and compositional analysis in non-malignant lung tissue
              samples obtained from 40 heavy smokers, including 10
              emphysema-only, 11 lung cancer-only, and 19 with both lung cancer
              and emphysema. RESULTS AND CONCLUSION: The emphysema-only group
              presented a lower bacterial community evenness defined by a
              significantly lower Shannon diversity index compared to the lung
              cancer patients with or without emphysema (P = 0.006).
              Furthermore, community compositions of lung cancer patients with
              or without emphysema were characterized by a significantly lower
              abundance of Proteobacteria (primary the genera Acinetobacter and
              Acidovorax) and higher prevalence of Firmicutes (Streptococcus)
              and Bacteroidetes (Prevotella), compared to emphysema-only
              patients. In conclusion, the lung microbial composition and
              communities structures of smokers with lung cancer are distinct
              from the emphysema-only patients. Although preliminary, our
              findings suggest that lung microbiome changes could be a
              biomarker of lung cancer that could eventually be used to help
              screening for the disease.",
  journal  = "Am. J. Cancer Res.",
  volume   =  8,
  number   =  9,
  pages    = "1775--1787",
  month    =  sep,
  year     =  2018,
  keywords = "16S rRNA gene; Lung cancer; bacteria; emphysema; microbiome",
  language = "en"
  url={https://pmc.ncbi.nlm.nih.gov/articles/30323970/}

  
}

@artcile{Unni2015-ns,
  % Thesis: KRAS and EGFR mutations have synthetic gene lethality excluding mutations in both of them. 
  % My opinions: A cursory examination of the paper indicates that the statistics seems to hold water, and the 
  % biology seems logical and like it would substantiate this. Plus, it explains a lot. 
  title     = "Evidence that synthetic lethality underlies the mutual
               exclusivity of oncogenic {KRAS} and {EGFR} mutations in lung
               adenocarcinoma",
  author    = "Unni, Arun M and Lockwood, William W and Zejnullahu, Kreshnik
               and Lee-Lin, Shih-Queen and Varmus, Harold",
  abstract  = "Human lung adenocarcinomas (LUAD) contain mutations in EGFR in
               ∼15\% of cases and in KRAS in ∼30\%, yet no individual
               adenocarcinoma appears to carry activating mutations in both
               genes, a finding we have confirmed by re-analysis of data from
               over 600 LUAD. Here we provide evidence that co-occurrence of
               mutations in these two genes is deleterious. In transgenic mice
               programmed to express both mutant oncogenes in the lung
               epithelium, the resulting tumors express only one oncogene. We
               also show that forced expression of a second oncogene in human
               cancer cell lines with an endogenous mutated oncogene is
               deleterious. The most prominent features accompanying loss of
               cell viability were vacuolization, other changes in cell
               morphology, and increased macropinocytosis. Activation of ERK,
               p38 and JNK in the dying cells suggests that an overly active
               MAPK signaling pathway may mediate the phenotype. Together, our
               findings indicate that mutual exclusivity of oncogenic mutations
               may reveal unexpected vulnerabilities and therapeutic
               possibilities.",
  journal   = "Elife",
  publisher = "eLife Sciences Publications, Ltd",
  volume    =  4,
  pages     = "e06907",
  month     =  jun,
  year      =  2015,
  keywords  = "human; human biology; lung cancer; medicine; mouse; oncogenes;
               synthetic lethality",
  copyright = "http://creativecommons.org/publicdomain/zero/1.0/",
  language  = "en"
  url={https://doi.org/10.7554/eLife.06907}
}

