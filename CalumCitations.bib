
%NOTE: to remove my commentary from this document, run `:%s/ *%.\+\n//g` in vi. This is important when I start trying to use these citations in papers and want to avoid pissing people off.

@article{liu2020microbiome,
   % Thesis: The authors of this review article claim that the literature supports the idea that the misregulation of lung microbiome has strong correlations with lung cancer.
   % My opinions: This article should be primarily used as a repository of different lung cancer microbiome articles (and also some other lung disorders). 
   % The English is noticeably off. Not literally incorrect, but so awkward and stilted that the actual semantic content of the article is difficult to read. 
   % That said, the article authors did seem to do a decent job compiling stuff. I didn't read their conclusions super thoroughly because of the English problem, though. 
  title={{Microbiome dysbiosis in lung cancer: from composition to therapy}},
  author={Liu, Ning-Ning and Ma, Qiang and Ge, Yang and Yi, Cheng-Xiang and Wei, Lu-Qi and Tan, Jing-Cong and Chu, Qiao and Li, Jing-Quan and Zhang, Peng and Wang, Hui},
  journal={{NPJ precision oncology}},
  volume={4},
  number={1},
  pages={33},
  year={2020},
  publisher={Nature Publishing Group UK London}
  url={https://doi.org/10.1038/s41698-020-00138-z}
}

@article{jin2019commensal,
  % Thesis: The authors claim that the lung microbiome can drive the development of lung cancer by activated gamma delta T cells, promoting neutrophil infiltration, inflammation, and tumor cell proliferation. 
  % My opinions: Before I even read the article, I was immediately sus. I don't think the authors are fundamentally _wrong_, but I definitely think the story has to be more complicated than "microbiome in lung bad"
  % These are my opinions as I read the article:
  %  The antibiotic nuke the researchers used is insane. Combining how much mouse drink in a day and comparing with high dose oral vancomycin in human adults indicated that the vancomycin in their antibiotic cocktail alone was about double the human staph infection amount relative to body weight. And they had three other drugs in there
  %  I can buy that they showed the microbiome mattering. I'm very annoyed that they made the thesis "lung microbiome bad" despite their own data showing that it was at least partially reduced diversity of the microbiome that matter. They barely showed that there was a correlation with the LUNG microbiome mattering more than the microbiome of other parts of the body. And that was just a correlation. Have they considered an aerosol of some kind to actually microbiome the lung?
  %  This is enough evidence to buy the possibility of lung microbiome being important, but the researchers were too reductive. And again, I can't get over the antibiotic nuke. 
  title={{Commensal microbiota promote lung cancer development via $\gamma$$\delta$ T cells}},
  author={Jin, Chengcheng and Lagoudas, Georgia K and Zhao, Chen and Bullman, Susan and Bhutkar, Arjun and Hu, Bo and Ameh, Samuel and Sandel, Demi and Liang, Xu Sue and Mazzilli, Sarah and others},
  journal={{Cell}},
  volume={176},
  number={5},
  pages={998--1013},
  year={2019},
  publisher={Elsevier}
  url={doi.org/10.1016/j.cell.2018.12.040}
}

@article{yan2015discovery,
  % Thesis: The authors claim to have found a decent classifier of lung cancer vs not based on oral microbiota, in particular by looking for elevated levels of Capnocytophaga and Veillonella in saliva. 
  % My opinions: Delicious. Finally, some good fucking food. 
  % Now, this might be of only so much help to me personally. This is a study that was specifically done on humans with a >10+ year history of smoking, and I'm specifically trying to do things on non smokers. 
  % But this study was done in China, and their rationale was the fairly simple, "[s]ince smoking may affect the growth of bacteria in the oral cavity, only subjects with a smoking history of over 10 years were selected"
  % I suspect strongly this was done out of availability: my understanding is that smoking rates in China are pretty high, and obviously P(smoking|Chinese lung cancer) > P(smoking|Chinese)
  % They also explicitly checked, "None of the subjects, including the patients and the controls, manifested other diseases related to salivary bacteria, such as diabetes, immune dysfunction, herpes viral infections, or oral mucosal ulcers"
  % The researchers looked for bacterial populations with elevated or reduced levels in saliva by comparing results in 30 people: 10 with squamous cell carcinoma, 10 with adenocarcinoma, and 10 patients without lung cancer. 
  % They found in their discovery group, "Capnocytophaga,  Selenomonas, and Veillonella were found to be more abundant in both SCC and AC patients, whereas Neisseria was less abundant in both SCC and AC patients than the controls"
  % When they validated, they did it on a new cohort of 56 people, (13 LUSC, 28 LUAD, 15 without cancer). Now, the main criticisms I have are all their samples are male biased and have a clear age difference between the groups (SCC older than AC older than control). Also, their cancer patients skewed heavily late stage
  % This is a minor criticism though: they noted it explicitly and I would put money on the table again that they were working with what they had. 
  % When they tried to validate, they found that the best classifier was looking for elevated Capnocytophaga and Veillonella, without looking for reduced Neisseria (which seemed to spoil their classifer)
  % They also found that Veillonella tended to be better at discriminating LUSC than LUAD, while the inverse was marginally true for Capnocytophaga. 
  % They did note that while Nesseria wasn't particularly good at _discriminating_ cancer from not, the reduced levels are supported by other cancers showing similar things. 
  title={{Discovery and validation of potential bacterial biomarkers for lung cancer}},
  author={Yan, Xinmin and Yang, Mingxia and Liu, Juan and Gao, Ruichen and Hu, Jihong and Li, Jiong and Zhang, Lijun and Shi, Yujia and Guo, Hongrong and Cheng, Jinluo and others},
  journal={{American Journal of Cancer Research}},
  volume={5},
  number={10},
  pages={3111},
  year={2015}
  url={https://pmc.ncbi.nlm.nih.gov/articles/PMC4656734/}
}
